# ============================================================
# .env — Variables d'environnement pour Docker
# Ce fichier est chargé automatiquement par docker-compose
# ============================================================

# URL du backend Spring Boot (accessible depuis le navigateur du client)
# En Docker, le backend tourne sur le PC de l'hôte -> utiliser localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# URL du WebSocket (même origine que l'API)
NEXT_PUBLIC_WS_URL=http://localhost:8080
